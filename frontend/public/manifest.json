{
  "manifest_version": 3,
  "name": "WorkZen",
  "version": "1.0.0",
  "description": "Adjustable Task Management & Focus Timer Dashboard.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "index.html",
    "default_title": "WorkZen"
